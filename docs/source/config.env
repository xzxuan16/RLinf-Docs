# Sphinx AI Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# =============================================================================
# Build Environment
# =============================================================================
SPHINX_ENV=development
SPHINX_DEBUG=false

# =============================================================================
# Typesense Search and AI Configuration
# =============================================================================
# Your Typesense server settings
TYPESENSE_HOST=typesense.product-team-dev.infini-ai.com
TYPESENSE_PORT=9443
TYPESENSE_PROTOCOL=https

# Get your API key from Typesense dashboard
# For search-only operations, use a search-scoped key (recommended)
TYPESENSE_API_KEY=hAvqOEYEbtQwuFvm0SeclKHmCX4QXgs3

# Collection name for your indexed documents
TYPESENSE_COLLECTION=infini-RL

# =============================================================================
# Development Configuration Examples
# =============================================================================
# For local development:
# TYPESENSE_HOST=typesense.product-team-dev.infini-ai.com
# TYPESENSE_PORT=9443
# TYPESENSE_PROTOCOL=https

# For production with HTTPS:
# TYPESENSE_HOST=typesense.product-team-dev.infini-ai.com
# TYPESENSE_PORT=9443
# TYPESENSE_PROTOCOL=https

# =============================================================================
# Notes
# =============================================================================
# 1. API keys should be kept secret - never commit them to version control
# 2. Use search-scoped API keys for Typesense when possible
# 3. Test your configuration by building: ./build_docs.sh
# 4. For production builds, set SPHINX_ENV=production
# 5. AI chat functionality is handled through Typesense conversation API
# 6. Ensure your Typesense server has AI conversation capabilities enabled 